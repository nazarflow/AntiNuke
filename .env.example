# ─── Discord ──────────────────────────────────────────────────────────────────
TOKEN=YOUR_BOT_TOKEN_HERE

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development (SQLite — no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./database.db

# Production (uncomment when using Docker / PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://antinuke:strongpassword@db:5432/antinuke

# ─── PostgreSQL (used by docker-compose only) ─────────────────────────────────
POSTGRES_USER=antinuke
POSTGRES_PASSWORD=strongpassword
POSTGRES_DB=antinuke

# ─── Web UI (FastAPI Dashboard) ───────────────────────────────────────────────
WEB_USER=admin
WEB_PASSWORD=admin
